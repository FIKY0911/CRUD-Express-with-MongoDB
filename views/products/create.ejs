<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Create New Product</title>
    <style>
        /* --- Base & Admin Panel Layout --- */
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
            background: linear-gradient(135deg, #0f172a 0%, #1e3a8a 100%);
            display: flex;
            min-height: 100vh;
            color: #1e293b;
        }

        /* --- Sidebar Style --- */
        .sidebar {
            width: 280px;
            background: linear-gradient(180deg, #1e293b 0%, #0f172a 100%);
            color: white;
            position: fixed;
            height: 100%;
            display: flex;
            flex-direction: column;
            box-shadow: 4px 0 20px rgba(0,0,0,0.3);
            z-index: 100;
        }

        .sidebar-header {
            padding: 30px 20px;
            font-size: 1.2rem;
            font-weight: 800;
            text-align: center;
            background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
            letter-spacing: 2px;
            color: #60a5fa;
        }

        .sidebar-menu {
            flex: 1;
            padding: 20px 0;
        }

        .sidebar-menu a {
            display: block;
            padding: 14px 20px;
            color: #cbd5e1;
            text-decoration: none;
            transition: all 0.3s ease;
            border-left: 3px solid transparent;
            margin: 8px 0;
            font-size: 0.95rem;
        }

        .sidebar-menu a:hover, .sidebar-menu a.active {
            background-color: rgba(96, 165, 250, 0.15);
            color: #60a5fa;
            border-left: 3px solid #60a5fa;
            transform: translateX(8px);
        }

        /* --- Main Content Area --- */
        .main-content {
            margin-left: 280px;
            flex: 1;
            display: flex;
            flex-direction: column;
        }

        .navbar {
            height: 70px;
            background-color: #fff;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 40px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.08);
            border-bottom: 1px solid #e2e8f0;
        }

        .navbar .user-info {
            font-weight: 600;
            color: #64748b;
            font-size: 0.9rem;
        }

        .breadcrumb {
            font-size: 0.85rem;
            color: #94a3b8;
            font-weight: 500;
        }

        .breadcrumb span {
            color: #1e293b;
            font-weight: 700;
        }

        .content-body {
            padding: 40px;
            display: flex;
            justify-content: center;
            background: #f8fafc;
            flex: 1;
        }

        /* --- Form Card Style --- */
        .form-card {
            width: 100%;
            max-width: 520px;
            background: #fff;
            padding: 45px;
            border-radius: 12px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
            border: 1px solid #e2e8f0;
        }

        h1 {
            font-size: 1.75rem;
            color: #1e293b;
            margin-bottom: 30px;
            text-align: center;
            font-weight: 700;
            letter-spacing: -0.5px;
        }

        .form-group {
            margin-bottom: 25px;
        }

        label {
            display: block;
            font-weight: 600;
            margin-bottom: 8px;
            color: #475569;
            font-size: 0.9rem;
            letter-spacing: 0.3px;
        }

        input[type="text"],
        input[type="number"],
        select {
            width: 100%;
            padding: 11px 14px;
            border: 1.5px solid #cbd5e1;
            border-radius: 8px;
            font-size: 0.95rem;
            transition: all 0.2s ease;
            outline: none;
            background-color: #f8fafc;
            color: #1e293b;
            font-family: inherit;
        }

        input::placeholder, select::placeholder {
            color: #94a3b8;
        }

        input:focus, select:focus {
            border-color: #3b82f6;
            background-color: #fff;
            box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.1);
        }

        /* --- Buttons --- */
        .btn-submit {
            width: 100%;
            background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
            color: white;
            padding: 12px 24px;
            border: none;
            border-radius: 8px;
            font-size: 0.95rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
            margin-top: 20px;
            box-shadow: 0 4px 12px rgba(59, 130, 246, 0.3);
            letter-spacing: 0.3px;
        }

        .btn-submit:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 16px rgba(59, 130, 246, 0.4);
        }

        .btn-submit:active {
            transform: translateY(0);
        }

        .btn-back {
            display: block;
            text-align: center;
            margin-top: 15px;
            text-decoration: none;
            color: #64748b;
            font-size: 0.85rem;
            transition: all 0.2s ease;
            font-weight: 500;
        }

        .btn-back:hover {
            color: #3b82f6;
            text-decoration: underline;
        }

        /* --- Responsive --- */
        @media (max-width: 768px) {
            .sidebar { width: 240px; }
            .main-content { margin-left: 240px; }
            .content-body { padding: 20px; }
            .form-card { padding: 30px 25px; }
            h1 { font-size: 1.5rem; }
            .navbar { padding: 0 20px; }
        }
    </style>
</head>
<body>

    <aside class="sidebar">
        <div class="sidebar-header">MYSHOP ADMIN</div>
        <nav class="sidebar-menu">
            <a href="/products" class="active">📦 Products Management</a>
            <a href="#">📊 Dashboard</a>
            <a href="#">🛒 Orders</a>
            <a href="#">👥 Customers</a>
            <a href="#">⚙️ Settings</a>
        </nav>
    </aside>

    <div class="main-content">
        <header class="navbar">
            <div class="breadcrumb">Admin / Products / <span>Create</span></div>
            <div class="user-info">Hello, Developer</div>
        </header>

        <main class="content-body">
            <div class="form-card">
                <h1>Create New Product</h1>
                <form action="/products" method="post">
                    <div class="form-group">
                        <label for="name">Nama Produk</label>
                        <input type="text" id="name" name="name" placeholder="Masukkan nama barang" required>
                    </div>
                    
                    <div class="form-group">
                        <label for="brand">Brand</label>
                        <input type="text" id="brand" name="brand" placeholder="Contoh: Nike, Zara, dll" required>
                    </div>
                    
                    <div class="form-group">
                        <label for="color">Warna</label>
                        <input type="text" id="color" name="color" placeholder="Warna dominan" required>
                    </div>
                    
                    <div class="form-group">
                        <label for="category">Kategori</label>
                        <select id="category" name="category" required>
                            <option value="">Pilih Kategori</option>
                            <option value="Aksesoris">Aksesoris</option>
                            <option value="Baju">Baju</option>
                            <option value="Celana">Celana</option>
                            <option value="Sepatu">Sepatu</option>
                            <option value="Jaket">Jaket</option>
                        </select>
                    </div>
                    
                    <div class="form-group">
                        <label for="price">Harga (IDR)</label>
                        <input type="number" id="price" name="price" step="0.01" placeholder="0.00" required>
                    </div>

                    <button type="submit" class="btn-submit">Save Product</button>
                    <a href="/products" class="btn-back">Cancel and Back to List</a>
                </form>
            </div>
        </main>
    </div>

</body>
</html>
