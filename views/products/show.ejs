<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Detail - <%= product.name %>
    </title>
    <style>
        /* --- Base & Admin Panel Layout --- */
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
            background: linear-gradient(135deg, #0f172a 0%, #1e3a8a 100%);
            display: flex;
            min-height: 100vh;
            color: #1e293b;
        }

        /* --- Sidebar Style --- */
        .sidebar {
            width: 280px;
            background: linear-gradient(180deg, #1e293b 0%, #0f172a 100%);
            color: white;
            position: fixed;
            height: 100%;
            display: flex;
            flex-direction: column;
            box-shadow: 4px 0 20px rgba(0, 0, 0, 0.3);
            z-index: 100;
        }

        .sidebar-header {
            padding: 30px 20px;
            font-size: 1.2rem;
            font-weight: 800;
            text-align: center;
            background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
            letter-spacing: 2px;
            color: #60a5fa;
        }

        .sidebar-menu {
            flex: 1;
            padding: 20px 0;
        }

        .sidebar-menu a {
            display: block;
            padding: 14px 20px;
            color: #cbd5e1;
            text-decoration: none;
            transition: all 0.3s ease;
            border-left: 3px solid transparent;
            margin: 8px 0;
            font-size: 0.95rem;
        }

        .sidebar-menu a:hover,
        .sidebar-menu a.active {
            background-color: rgba(96, 165, 250, 0.15);
            color: #60a5fa;
            border-left: 3px solid #60a5fa;
            transform: translateX(8px);
        }

        /* --- Main Content Area --- */
        .main-content {
            margin-left: 280px;
            flex: 1;
            display: flex;
            flex-direction: column;
        }

        .navbar {
            height: 70px;
            background-color: #fff;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 40px;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
            border-bottom: 1px solid #e2e8f0;
        }

        .navbar .user-info {
            font-weight: 600;
            color: #64748b;
            font-size: 0.9rem;
        }

        .breadcrumb {
            font-size: 0.85rem;
            color: #94a3b8;
            font-weight: 500;
        }

        .breadcrumb span {
            color: #1e293b;
            font-weight: 700;
        }

        .content-body {
            padding: 40px;
            display: flex;
            justify-content: center;
            background: #f8fafc;
            flex: 1;
        }

        /* --- Detail Card Style --- */
        .detail-card {
            width: 100%;
            max-width: 580px;
            background: #fff;
            padding: 45px;
            border-radius: 12px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
            border: 1px solid #e2e8f0;
        }

        h1 {
            font-size: 2rem;
            color: #1e293b;
            margin-bottom: 8px;
            text-align: center;
            font-weight: 700;
            letter-spacing: -0.5px;
        }

        .brand-subtitle {
            display: block;
            text-align: center;
            color: #64748b;
            font-size: 0.9rem;
            margin-bottom: 30px;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            font-weight: 600;
        }

        .info-section {
            background: #f1f5f9;
            border-radius: 10px;
            padding: 25px;
            margin-bottom: 30px;
            border-left: 4px solid #3b82f6;
        }

        ul {
            list-style: none;
        }

        li {
            padding: 14px 0;
            border-bottom: 1px solid #e2e8f0;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        li:last-child {
            border-bottom: none;
        }

        li strong {
            color: #1e293b;
            font-weight: 600;
            font-size: 0.9rem;
            min-width: 80px;
        }

        li span {
            color: #475569;
            text-align: right;
        }

        .price-tag {
            font-size: 1.4rem;
            color: #059669;
            font-weight: 700;
            font-family: 'Inter', system-ui, sans-serif;
        }

        .category-pill {
            background: rgba(59, 130, 246, 0.1);
            color: #3b82f6;
            padding: 4px 12px;
            border-radius: 9999px;
            text-decoration: none;
            font-size: 0.85rem;
            font-weight: 600;
            transition: all 0.2s;
            border: 1px solid rgba(59, 130, 246, 0.2);
        }

        .category-pill:hover {
            background: #3b82f6;
            color: white;
        }

        /* --- Buttons --- */
        .actions {
            display: flex;
            gap: 12px;
        }

        .btn {
            flex: 1;
            text-align: center;
            padding: 12px 20px;
            text-decoration: none;
            border-radius: 8px;
            font-weight: 600;
            transition: all 0.2s ease;
            border: none;
            cursor: pointer;
            font-size: 0.9rem;
            letter-spacing: 0.2px;
        }

        .btn-back {
            background-color: #f1f5f9;
            color: #475569;
            border: 1.5px solid #cbd5e1;
        }

        .btn-back:hover {
            background-color: #e2e8f0;
            border-color: #94a3b8;
            transform: translateY(-2px);
            box-shadow: 0 4px 10px rgba(0, 0, 0, 0.08);
        }

        .btn-edit {
            background: linear-gradient(135deg, #f59e0b, #d97706);
            color: white;
            box-shadow: 0 4px 12px rgba(245, 158, 11, 0.3);
        }

        .btn-edit:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 16px rgba(245, 158, 11, 0.4);
        }

        .btn-delete {
            background: linear-gradient(135deg, #ef4444, #dc2626);
            color: white;
            box-shadow: 0 4px 12px rgba(239, 68, 68, 0.3);
        }

        .btn-delete:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 16px rgba(239, 68, 68, 0.4);
        }

        /* --- Responsive --- */
        @media (max-width: 768px) {
            .sidebar {
                width: 240px;
            }

            .main-content {
                margin-left: 240px;
            }

            .content-body {
                padding: 20px;
            }

            .detail-card {
                padding: 30px 25px;
            }

            h1 {
                font-size: 1.6rem;
            }

            .actions {
                flex-direction: column;
            }

            .navbar {
                padding: 0 20px;
            }
        }
    </style>
</head>

<body>

    <aside class="sidebar">
        <div class="sidebar-header">MYSHOP ADMIN</div>
        <nav class="sidebar-menu">
            <a href="/products" class="active">📦 Products Management</a>
            <a href="#">📊 Dashboard</a>
            <a href="#">🛒 Orders</a>
            <a href="#">👥 Customers</a>
            <a href="#">⚙️ Settings</a>
        </nav>
    </aside>

    <div class="main-content">
        <header class="navbar">
            <div class="breadcrumb">Admin / Products / <span>Detail</span></div>
            <div class="user-info">Hello, Developer</div>
        </header>

        <main class="content-body">
            <div class="detail-card">
                <h1>
                    <%= product.name %>
                </h1>
                <span class="brand-subtitle">
                    <%= product.brand %>
                </span>

                <div class="info-section">
                    <ul>
                        <li>
                            <strong>Brand</strong>
                            <span><%= product.brand %></span>
                        </li>
                        <li>
                            <strong>Warna</strong>
                            <span><%= product.color %></span>
                        </li>
                        <li>
                            <strong>Kategori</strong>
                            <span>
                                <a href="/products?category=<%= product.category %>" class="category-pill">
                                    <%= product.category %>
                                </a>
                            </span>
                        </li>
                        <li>
                            <strong>Harga</strong>
                            <span class="price-tag">Rp <%= product.price.toLocaleString('id-ID') %></span>
                        </li>
                    </ul>
                </div>

                <div class="actions">
                    <a href="/products" class="btn btn-back">← Back to List</a>
                    <a href="/products/<%=product._id%>/edit" class="btn btn-edit">Edit Product</a>
                    <form action="/products/<%= product._id %>" method="post" style="flex: 1; display: flex;">
                        <input type="hidden" name="_method" value="DELETE">
                        <button type="submit" class="btn btn-delete" style="width: 100%;" onclick="return confirm('Are you sure you want to delete this product?')">Delete Product</button>
                    </form>
                </div>
            </div>
        </main>
    </div>

</body>

</html>
